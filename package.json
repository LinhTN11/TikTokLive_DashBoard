{
    "name": "tiktok-live-connector",
    "version": "2.1.1-beta1",
    "description": "Node.js library to receive live stream chat events like comments and gifts from TikTok LIVE.",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=20.0.0"
    },
    "workspaces": [
        "apps/live-overlay"
    ],
    "scripts": {
        "start": "npm run start:live",
        "dev:live": "npm --workspace @tiktok-live-connector/live-overlay run dev",
        "build": "tsx update-version.ts && npm run build:copy-package && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "build:live": "npm --workspace @tiktok-live-connector/live-overlay run build",
        "start:live": "npm --workspace @tiktok-live-connector/live-overlay run start",
        "typecheck:live": "npm --workspace @tiktok-live-connector/live-overlay run typecheck",
        "db:live:check": "node scripts/check-live-overlay-migrations.mjs && node scripts/check-live-overlay-domain.mjs",
        "db:live:apply": "node scripts/apply-live-overlay-schema.mjs",
        "build:copy-package": "cpx package.json dist && cpx LICENSE dist"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/zerodytrash/TikTok-Live-Connector.git"
    },
    "funding": [
        "https://buymeacoffee.com/zerody"
    ],
    "keywords": [
        "tiktok",
        "tiktok live",
        "tiktok.com",
        "live",
        "stream",
        "livestream",
        "chat",
        "connector",
        "api",
        "webcast",
        "tracker",
        "scraper",
        "websocket",
        "bot",
        "broadcast",
        "reader"
    ],
    "author": "zerodytrash",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/zerodytrash/TikTok-Live-Connector/issues"
    },
    "homepage": "https://github.com/zerodytrash/TikTok-Live-Connector#readme",
    "dependencies": {
        "@bufbuild/protobuf": "^2.2.5",
        "@eulerstream/euler-api-sdk": "0.2.0-beta1",
        "axios": "^1.12.2",
        "callable-instance": "^2.0.0",
        "typed-emitter": "^2.1.0",
        "typescript": "^5.9.3",
        "tsx": "^4.21.0",
        "ws": "^8.18.2"
    },
    "devDependencies": {
        "@types/node": "^22.15.3",
        "@types/ws": "^8.18.1",
        "cpx": "^1.5.0",
        "prettier": "2.5.1",
        "ts-proto": "^2.6.1",
        "tsc-alias": "^1.8.15"
    }
}
